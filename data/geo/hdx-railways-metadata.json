{"help": "https://data.humdata.org/api/3/action/help_show?name=package_show", "success": true, "result": {"archived": false, "batch": "1cfef687-7ea0-4951-9671-ef886fbe9ec6", "caveats": "OpenStreetMap data is crowd sourced and cannot be considered to be exhaustive", "creator_user_id": "6a0688ce-8521-46e2-8edd-8e26c0851ebd", "data_update_frequency": "30", "dataset_date": "[2026-05-10T00:00:00 TO 2026-05-10T23:59:59]", "dataset_preview": "first_resource", "dataset_source": "OpenStreetMap contributors", "due_date": "2026-06-09T23:59:59", "has_geodata": true, "has_showcases": false, "id": "9be4e203-f10b-49d1-9a71-ac396b47c87e", "is_requestdata_type": false, "isopen": false, "last_modified": "2026-05-14T17:07:51.284430", "license_id": "hdx-odc-odbl", "license_title": "Open Database License (ODC-ODbL)", "license_url": "https://opendatacommons.org/licenses/odbl/1-0/", "maintainer": "6a0688ce-8521-46e2-8edd-8e26c0851ebd", "metadata_created": "2021-03-07T04:42:15.823843", "metadata_modified": "2026-05-15T10:22:42.733438", "methodology": "Other", "methodology_other": "Volunteered geographic information", "name": "hotosm_kor_railways", "notes": "Railway lines and stations from OSM, tagged with `railway`. Includes rail lines, tram tracks, and stations. Useful for transport accessibility analysis and basemap context.\n\nOpenStreetMap is a free, collaborative world map built by volunteers. Completeness varies by region: urban areas are usually well-mapped, remote areas may be incomplete. Cross-check critical decisions with local field knowledge.\n\n- Source: [OpenStreetMap](https://www.openstreetmap.org)\n- OSM tags: [Key:railway](https://wiki.openstreetmap.org/wiki/Key:railway)\n- Part of many  [exports grid on HDX](https://data.humdata.org/organization/hot) by the [HOT](https://www.hotosm.org/en/)\n", "num_resources": 5, "num_tags": 4, "organization": {"id": "225b9f7d-e7cb-4156-96a6-44c9c58d31e3", "name": "hot", "title": "Humanitarian OpenStreetMap Team (HOT)", "type": "organiza