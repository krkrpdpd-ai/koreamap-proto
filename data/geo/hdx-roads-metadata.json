{"help": "https://data.humdata.org/api/3/action/help_show?name=package_show", "success": true, "result": {"archived": false, "batch": "1cfef687-7ea0-4951-9671-ef886fbe9ec6", "caveats": "OpenStreetMap data is crowd sourced and cannot be considered to be exhaustive", "creator_user_id": "6a0688ce-8521-46e2-8edd-8e26c0851ebd", "data_update_frequency": "30", "dataset_date": "[2026-05-10T00:00:00 TO 2026-05-10T23:59:59]", "dataset_preview": "first_resource", "dataset_source": "OpenStreetMap contributors", "due_date": "2026-06-09T23:59:59", "has_geodata": true, "has_showcases": false, "id": "f4aecc09-71f7-4350-bb2c-a4706d8875fc", "is_requestdata_type": false, "isopen": false, "last_modified": "2026-05-14T17:06:43.039197", "license_id": "hdx-odc-odbl", "license_title": "Open Database License (ODC-ODbL)", "license_url": "https://opendatacommons.org/licenses/odbl/1-0/", "maintainer": "6a0688ce-8521-46e2-8edd-8e26c0851ebd", "metadata_created": "2021-03-07T04:42:10.696717", "metadata_modified": "2026-05-15T11:25:00.579582", "methodology": "Other", "methodology_other": "Volunteered geographic information", "name": "hotosm_kor_roads", "notes": "Road network across the region from OSM. Includes everything tagged with `highway`: motorways, residential streets, service roads, footways, and trails. Useful for routing, accessibility analysis, and evacuation planning.\n\nOpenStreetMap is a free, collaborative world map built by volunteers. Completeness varies by region: urban areas are usually well-mapped, remote areas may be incomplete. Cross-check critical decisions with local field knowledge.\n\n- Source: [OpenStreetMap](https://www.openstreetmap.org)\n- OSM tags: [Key:highway](https://wiki.openstreetmap.org/wiki/Key:highway)\n- Part of many  [exports grid on HDX](https://data.humdata.org/organization/hot) by the [HOT](https://www.hotosm.org/en/)\n", "num_resources": 4, "num_tags": 3, "organization": {"id": "225b9f7d-e7cb-4156-96a6-44c9c58d31e3", "name": "hot", "title": "Humanitaria